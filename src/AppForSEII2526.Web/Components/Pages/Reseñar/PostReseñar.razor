@page "/reseñar/createreview"

@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<PostReseñar> logger
@inject ReseñarStateContainer reseñarState
@inject NavigationManager navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Publicar Reseña</h3>

<EditForm Model="reseña" OnValidSubmit="GuardarDirecto" OnInvalidSubmit="MostrarErroresValidacion">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>

    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p>@messageError</p>
    </div>

    @* DATOS DE USUARIO *@
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                @* ID necesario  "Usuario" *@
                <InputText @bind-Value="reseña.Usuario" class="form-control" id="Usuario" placeholder="Usuario" />
                <label for="Usuario">Usuario (Obligatorio)</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                @* ID necesario "Pais" *@
                <InputText @bind-Value="reseña.Pais" class="form-control" id="Pais" />
                <label for="Pais">País</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-flo "TipoConductor" *@
                <InputSelect @bind-Value="reseña.TipoConductor" class="form-select" id="TipoConductor">
                    <option value="Titular">Titular</option>
                    <option value="Adicional">Adicional</option>
                </InputSelect>
                <label for="TipoConductor">Tipo de Conductor</label>
            </div>
        </div>
    </div>

    <div class="col-md">
        <div class="form-floating">
            @* ID necesario "Submit" *@
            <button class="btn btn-primary" type="submit" id="Submit" disabled="@isProcesando">
                @if (isProcesando)
                {
                    <span>Enviando...</span>
                }
                else
                {
                    <span>Finalizar Reseña</span>
                }
            </button>
        </div>
    </div>

    <hr />

    <h4>Coches a reseñar</h4>
    <p>
        @* ID necesario: "ModifyCar" *@
        <button class="btn btn-outline-primary" type="button" id="ModifyCar" @onclick="VolverASeleccion">
            Modificar lista
        </button>
    </p>

    <div class="mh-100 table-responsive">
        @* ID necesario "TableOfReviewItems" *@
        <table class="table table-condensed table-hover" id="TableOfReviewItems">
            <thead>
                <tr>
                    <th>Coche</th>
                    <th>Puntuación (1-5)</th>
                    <th>Descripción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in reseña.ReseñarItems)
                {
                    <tr>
                        <td>@item.CocheNombre</td>
                        <td style="width: 150px;">
                            @* ID Dinámico "rating_{id}" *@
                            <InputNumber @bind-Value="item.Calificacion"
                                         class="form-control"
                                         min="1" max="5"
                                         id="@("rating_" + item.CocheId)" />
                        </td>
                        <td>
                            @* ID Dinámico  "description_{id}" *@
                            <InputTextArea @bind-Value="item.Descripcion"
                                           class="form-control"
                                           placeholder="Ej: Reseña para..."
                                           id="@("description_" + item.CocheId)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@code {
    private string messageError = "";
    private bool hideErrors => string.IsNullOrEmpty(messageError);
    private bool isProcesando = false;

    private CreacionesReseñarDTO reseña => reseñarState.Reseña;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            reseña.Usuario = user.Identity.Name;
        }

       
        // Inicializamos la fecha para evitar error 
        reseña.Creado = DateTime.Now;
        

        // if (string.IsNullOrEmpty(reseña.Pais)) reseña.Pais = "España"; fallan los test
        if (string.IsNullOrEmpty(reseña.TipoConductor)) reseña.TipoConductor = "Titular";
    }

    private void VolverASeleccion()
    {
        navigation.NavigateTo("/reseñar/select");
    }

    private void MostrarErroresValidacion()
    {
        messageError = "Faltan datos obligatorios.";
    }

    private async Task GuardarDirecto()
    {
        isProcesando = true;
        messageError = "";

        if (reseña.ReseñarItems.Count == 0)
        {
            messageError = "No hay coches seleccionados.";
            isProcesando = false;
            return;
        }

        try
        {
            var reviewed = await apiclient.CreateAsync(reseña);
            reseñarState.ReseñaProcesada();
            navigation.NavigateTo($"/reseñar/details?id={reviewed.Id}");
        }
        catch (ApiException<ValidationProblemDetails> ex)
        {
            if (ex.Result.Errors != null)
            {
                var erroresBackend = "";
                foreach (var errorList in ex.Result.Errors.Values)
                {
                    erroresBackend += string.Join(" | ", errorList) + ". ";
                }
                messageError = "Error del Servidor: " + erroresBackend;
            }
        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == 201 || ex.StatusCode == 200)
            {
                try
                {
                    var json = ex.Response;
                    var partes = json.Split(new[] { "\"id\":" }, StringSplitOptions.None);
                    if (partes.Length > 1)
                    {
                        var idParte = partes[1].Split(',')[0].Trim();
                        int id = int.Parse(idParte);
                        reseñarState.ReseñaProcesada();
                        navigation.NavigateTo($"/reseñar/details?id={id}");
                        return;
                    }
                }
                catch
                {
                    messageError = "Reseña guardada (201), pero no pude leer el ID.";
                }
            }
            else
            {
                messageError = $"Error de API ({ex.StatusCode}): {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            messageError = $"Error crítico: {ex.Message}";
        }
        finally
        {
            isProcesando = false;
        }
    }
}